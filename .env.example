# Worksection MCP Server Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# OAuth2 Configuration (REQUIRED)
# =============================================================================
# Get these from your Worksection OAuth2 app settings
WORKSECTION_CLIENT_ID=your_client_id_here
WORKSECTION_CLIENT_SECRET=your_client_secret_here

# Your Worksection account URL (without trailing slash)
WORKSECTION_ACCOUNT_URL=https://yourcompany.worksection.com

# OAuth2 redirect URI - must match the one registered in your Worksection app
# NOTE: Worksection requires HTTPS for OAuth2 redirect URIs
WORKSECTION_REDIRECT_URI=https://localhost:8080/oauth/callback

# OAuth2 scopes (comma-separated, no spaces)
# Available: projects_read, tasks_read, costs_read, tags_read, comments_read, files_read, users_read, contacts_read, administrative
WORKSECTION_SCOPES=projects_read,tasks_read,costs_read,tags_read,comments_read,files_read,users_read,contacts_read,administrative

# =============================================================================
# OAuth2 Flow Settings
# =============================================================================
# Host and port for the OAuth callback server
OAUTH_CALLBACK_HOST=localhost
OAUTH_CALLBACK_PORT=8080

# Automatically open browser for OAuth authorization
OAUTH_AUTO_OPEN_BROWSER=true

# =============================================================================
# SSL Configuration for OAuth Callback
# =============================================================================
# Use HTTPS for OAuth callback server (required by Worksection)
OAUTH_CALLBACK_USE_SSL=true

# Path to SSL certificate file (auto-generated if missing)
OAUTH_SSL_CERT_PATH=./data/certs/callback.crt

# Path to SSL private key file (auto-generated if missing)
OAUTH_SSL_KEY_PATH=./data/certs/callback.key

# Certificate validity in days for auto-generated certificates
OAUTH_SSL_CERT_DAYS=3650

# =============================================================================
# Token Management
# =============================================================================
# Directory for storing encrypted tokens
TOKEN_STORAGE_PATH=./data/tokens

# Encryption key for tokens (auto-generated if empty)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# =============================================================================
# File Caching
# =============================================================================
# Directory for cached file attachments
FILE_CACHE_PATH=./data/files

# How long to keep cached files (hours)
FILE_CACHE_RETENTION_HOURS=72

# Maximum file size to cache (MB)
MAX_FILE_SIZE_MB=100

# =============================================================================
# MCP Server Configuration
# =============================================================================
# Server name (used in MCP protocol)
MCP_SERVER_NAME=worksection

# Server bind host for HTTP transports (streamable-http / sse):
# - 127.0.0.1: local machine only (default, safer)
# - 0.0.0.0: LAN/external access
MCP_SERVER_HOST=127.0.0.1

# Server port for HTTP transports
MCP_SERVER_PORT=8000

# Transport type: streamable-http (recommended), sse (legacy), or stdio
MCP_TRANSPORT=streamable-http

# =============================================================================
# Runtime Configuration
# =============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Environment: development, staging, production
ENVIRONMENT=development
