{
  "hooks": {
    "post-edit": [
      {
        "name": "Format Python files with uv",
        "pattern": "**/*.py",
        "command": "uv run ruff format {file} 2>&1 || true",
        "background": true
      },
      {
        "name": "Lint Markdown files",
        "pattern": "**/*.md",
        "command": "npx markdownlint-cli2 --fix {file} 2>&1 || true",
        "background": true
      }
    ]
  }
}
